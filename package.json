{
  "name": "nhsuk-service-manual",
  "version": "8.12.0",
  "description": "NHS digital service manual",
  "engines": {
    "node": "^20.9.0 || ^22.11.0",
    "npm": "^10.5.0"
  },
  "main": "app/index.js",
  "scripts": {
    "prebuild": "npm run clean",
    "build": "webpack",
    "clean": "del-cli public/**",
    "lint": "npm run lint:types && npm run lint:js && npm run lint:css && npm run lint:prettier",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run lint:prettier:fix",
    "lint:prettier": "prettier --cache --cache-location .cache/prettier --cache-strategy content --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:js": "eslint --cache --cache-location .cache/eslint --cache-strategy content --color --max-warnings 0 .",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:css": "stylelint --cache --cache-location .cache/stylelint --cache-strategy content --color --formatter verbose --ignore-path .gitignore --max-warnings 0 \"**/*.{md,scss}\"",
    "lint:css:fix": "npm run lint:css -- --fix",
    "lint:types": "tsc --build tsconfig.json --pretty",
    "nuke": "npm run clean && rm -rf node_modules/",
    "start": "node .",
    "pretest": "npm run lint && npm run build",
    "test": "npm run test:js",
    "test:js": "jest --color",
    "watch": "concurrently --prefix none npm:watch:*",
    "watch:build": "npm run build -- --watch",
    "watch:start": "node --watch ."
  },
  "author": "https://github.com/nhsuk",
  "repository": {
    "type": "git",
    "url": "https://github.com/nhsuk/nhsuk-service-manual.git"
  },
  "license": "MIT",
  "dependencies": {
    "@open-iframe-resizer/core": "^2.3.1",
    "@prettier/sync": "^0.6.1",
    "accessible-autocomplete": "^3.0.1",
    "axios": "^1.16.0",
    "basic-auth": "^2.0.1",
    "browser-sync": "^3.0.4",
    "cheerio": "^1.2.0",
    "chokidar": "^3.6.0",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "highlight.js": "^11.11.1",
    "js-beautify": "^1.15.4",
    "lunr": "^2.3.9",
    "marked": "^18.0.3",
    "nhsuk-frontend": "^10.5.1",
    "nunjucks": "^3.2.4",
    "outdent": "^0.8.0",
    "slug": "^9.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/basic-auth": "^1.1.8",
    "@types/browser-sync": "^2.29.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lunr": "^2.3.7",
    "@types/nunjucks": "^3.2.6",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "concurrently": "^10.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "cssnano": "^8.0.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-es-x": "^9.6.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-node-import": "^1.2.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.3.0",
    "jsdom-testing-mocks": "^1.16.0",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "postcss-loader": "^8.2.1",
    "postcss-markdown": "^1.3.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.4",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^17.0.0",
    "stylelint": "^17.13.0",
    "stylelint-config-gds": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "typed-query-selector": "^2.12.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "files": [
    "app",
    "lib",
    "middleware",
    "public",
    "!**/*.test.*"
  ]
}
