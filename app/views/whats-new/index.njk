{% extends "layouts/app-layout.njk" %}

{% set pageTitle = "What's new" %}
{% set pageDescription = "Find out what's happening with the service manual." %}
{% set pageSection = "What's new" %}
{% set landingPage = true %}

{% block bodyContent %}

  <h2>Latest updates</h2>

  <h3>April 2026</h3>

  {% set contentHtml %}
    <p>Updated <a href="/content/writing-nhs-messages#nhs-app-messages">NHS App greeting section in Writing NHS messages</a></p>
  {% endset %}

  {% set designHtml %}
    <p>Updated <a href="/design-system/components/card">card component</a></p>
    <p>Split out <a href="/design-system/patterns/hub-page">hub page pattern</a> from card component page</a></p>
    <p>Added section on <a href="/design-system/components/date-input#using-autocomplete-attribute">using autocomplete attribute to date input</a></p>
  {% endset %}

  {% set otherHtml %}
    <p>Updated <a href="/accessibility-statement">accessibility statement</a> after latest audit</p>
  {% endset %}

  {{ table({
    caption: "Updates to the service manual in April 2026",
    captionClasses: "nhsuk-u-visually-hidden",
    head: [
      {
        text: "Section",
        classes: "nhsuk-u-width-one-quarter"
      },
      {
        text: "Update"
      }
    ],
    rows: [
      [
        {
          text: "Content"
        },
        {
          html: contentHtml
        }
      ],
      [
        {
          text: "Design system"
        },
        {
          html: designHtml
        }
      ],
      [
        {
          text: "Other"
        },
        {
          html: otherHtml
        }
      ]
    ]
  }) }}

  <p><a href="/whats-new/updates">See all updates</a></p>

  <h2>Latest blog posts</h2>
  <p>Posts by the service manual team and community.</p>

  <div class="nhsuk-grid-row nhsuk-card-group">
    <div class="nhsuk-grid-column-one-half nhsuk-card-group__item">
      {% call card({
        image: {
          src: "/assets/blog-prototype-kit.png"
        },
        clickable: true,
        href: "#",
        heading: "One design system is better than 2",
        headingLevel: 3
      }) %}
        <p class="nhsuk-body-s nhsuk-u-secondary-text-colour nhsuk-u-margin-bottom-0"><span class="nhsuk-u-visually-hidden">Published on: </span>21 April 2026</p>
        <p class="nhsuk-body-s nhsuk-u-font-weight-bold">NHS England Design Matters blog</p>
        <p class="nhsuk-card__description">Frankie and Ananda explain why the NHS design system is not just for public-facing services, with an overview of recent changes to meet the needs of staff-facing services. There's also more change coming, and you can get involved too.</p>
      {% endcall %}
    </div>
    <div class="nhsuk-grid-column-one-half nhsuk-card-group__item">
      {% call card({
        image: {
          src: "/assets/blog-post-frontend-v10.jpg"
        },
        clickable: true,
        href: "https://digital.nhs.uk/blog/design-matters/2025/making-the-nhs-design-system-fit-for-the-future",
        heading: "Making the NHS design system fit for the future",
        headingLevel: 3
      }) %}
        <p class="nhsuk-body-s nhsuk-u-secondary-text-colour nhsuk-u-margin-bottom-0"><span class="nhsuk-u-visually-hidden">Published on: </span>31 October 2025</p>
        <p class="nhsuk-body-s nhsuk-u-font-weight-bold">NHS England Design Matters blog</p>
        <p class="nhsuk-card__description">Tero Väänänen explains why the NHS design system exists and why it plays an important role in fulfilling the 10-year health plan. He also describes recent changes to the frontend code behind the design system, and why it is important for teams to adopt them now.</p>
      {% endcall %}
    </div>
  </div>

  <p><a href="/whats-new/blog-posts">See all blog posts</a></p>

