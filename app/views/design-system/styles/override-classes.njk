{% extends "layouts/app-layout.njk" %}

{% set pageTitle = "Override classes" %}
{% set pageDescription = "A reference list of all override classes provided by the design system, grouped by category." %}
{% set pageSection = "Design system" %}
{% set subSection = "Styles" %}
{% set theme = "Reference" %}
{% set dateUpdated = "July 2026" %}

{% block beforeContent %}
  {% include "design-system/_breadcrumb.njk" %}
{% endblock %}

{% block bodyContent %}
  <p>You can change the default appearance of components by using override classes, sometimes known as "utility classes".</p>

  <p>Override classes provided by the design system all have the prefix <code>nhsuk-u-</code>.</p>

  <h2>Spacing</h2>

  <p>Spacing override classes control the margin and padding on elements. They come in 2 types: responsive and static. See the <a href="/design-system/styles/spacing">spacing styles page</a> for guidance on when and how to use spacing.</p>

  <h3>Responsive spacing</h3>

  <p>Responsive spacing classes apply different values on mobile and on tablet and larger screens. You can replace <code>0</code> with any number from 0 to 9.</p>

  {{ summaryList({
    rows: [
      {
        key: { html: "<code>nhsuk-u-margin-0</code>", classes: "nhsuk-u-width-one-half" },
        value: { text: "Responsive margin on all sides" }
      },
      {
        key: { html: "<code>nhsuk-u-margin-top-0</code>" },
        value: { text: "Responsive margin on the top" }
      },
      {
        key: { html: "<code>nhsuk-u-margin-right-0</code>" },
        value: { text: "Responsive margin on the right" }
      },
      {
        key: { html: "<code>nhsuk-u-margin-bottom-0</code>" },
        value: { text: "Responsive margin on the bottom" }
      },
      {
        key: { html: "<code>nhsuk-u-margin-left-0</code>" },
        value: { text: "Responsive margin on the left" }
      },
      {
        key: { html: "<code>nhsuk-u-padding-0</code>" },
        value: { text: "Responsive padding on all sides" }
      },
      {
        key: { html: "<code>nhsuk-u-padding-top-0</code>" },
        value: { text: "Responsive padding on the top" }
      },
      {
        key: { html: "<code>nhsuk-u-padding-right-0</code>" },
        value: { text: "Responsive padding on the right" }
      },
      {
        key: { html: "<code>nhsuk-u-padding-bottom-0</code>" },
        value: { text: "Responsive padding on the bottom" }
      },
      {
        key: { html: "<code>nhsuk-u-padding-left-0</code>" },
        value: { text: "Responsive padding on the left" }
      }
    ]
  }) }}

