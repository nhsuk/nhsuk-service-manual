      <h2 class="nhsuk-heading-l">Example 1</h2>
      <p class="nhsuk-body-s nhsuk-u-secondary-text-colour">Updated: February 2026 - <a href="javascript:void(0)" onclick="toggleContent(this, 'content1')">See all updates</a></p>

