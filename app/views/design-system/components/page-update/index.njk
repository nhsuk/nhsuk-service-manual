      <script>
      function toggleContent(linkElement, contentId) {
        var content = document.getElementById(contentId);

        if (content.style.display === "none") {
        content.style.display = "block";
        linkElement.innerHTML = "Hide all updates"; 
       } else {
        content.style.display = "none";
        linkElement.innerHTML = "Show all updates"; 
        }
      } 
      </script>










